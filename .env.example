# MT5 Connection Credentials
# These are optional but recommended if you need to auto-login.
MT5_LOGIN=12345678
MT5_PASSWORD=your_secure_password
MT5_SERVER=Your-Broker-Server

# MT5 Installation Path
# This is usually required if you have multiple MT5 terminals or if the script can't find MT5 automatically.
# Default location is usually: C:\Program Files\MetaTrader 5\terminal64.exe
# Leave this blank if your MT5 is already opening automatically without it.
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
